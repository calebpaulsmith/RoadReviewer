# Build artifacts - assembled per docs/build-and-import.md.
# Pattern catches RoadReviewer.xlsm, "RoadReviewer (1).xlsm" downloads-style
# duplicates, and Excel's ~$ lock files.
build/RoadReviewer*.xlsm
build/~$*.xlsm

# Prototype VBA dump (for reading reference only; the source of truth
# is the prototype .xlsm files themselves)
build/prototype-vba/

# Local IDE/agent state
.claude/

# Node deps for the web-test verifiers (build/web-tests, playwright-core)
node_modules/
# Python cache from running the notebook script locally
__pycache__/

# Inspector output (FIRMettes, Map PDFs, KML, CSV) — generated per WO
# by the workflows; never source of truth, never committed.
Output/
